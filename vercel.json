{
  "installCommand": "corepack enable && pnpm install --no-frozen-lockfile --prod=false",
  "buildCommand": "cd /vercel/path0 && pnpm --filter @workspace/api-server run build && pnpm --filter @workspace/interfreight run build && node /vercel/path0/scripts/copy-vercel-output.mjs",
  "outputDirectory": "public",
  "functions": {
    "api/index.mjs": {
      "maxDuration": 60,
      "includeFiles": "{artifacts/api-server/dist/**,node_modules/@swc/helpers/**,node_modules/.pnpm/@swc+helpers*/node_modules/@swc/helpers/**,artifacts/api-server/node_modules/@swc/helpers/**,artifacts/api-server/node_modules/.pnpm/@swc+helpers*/node_modules/@swc/helpers/**}"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}

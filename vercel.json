{
  "installCommand": "corepack enable && pnpm install --no-frozen-lockfile --prod=false",
  "buildCommand": "cd /vercel/path0 && pnpm --filter @workspace/api-server run build && pnpm --filter @workspace/interfreight run build && node /vercel/path0/scripts/copy-vercel-output.mjs",
  "outputDirectory": "public",
  "functions": {
    "api/index.mjs": {
      "maxDuration": 60,
      "includeFiles": "artifacts/api-server/dist/**"
    }
  },
  "crons": [
    {
      "path": "/api/notifications/remind-unread",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/notifications/remind-documents",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/notifications/remind-unread",
      "schedule": "0 13 * * *"
    },
    {
      "path": "/api/notifications/remind-documents",
      "schedule": "0 13 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
